DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Shared "secret word" that gates the login/signup forms (losje access).
CUSTOMER_PASSWORD="coffee"
# Signs session/gate cookies and login codes. Use a long random string.
SESSION_SECRET="replace-with-random-string"
# Comma-separated emails that always get admin access (bootstrap admins).
ADMIN_EMAILS="you@example.com"
VIPPS_PHONE_NUMBER="4712345678"

PICKUP_CALENDAR_ICS_URL="https://..."
PICKUP_EVENT_KEYWORD="henting"
PICKUP_MAX_DAYS_AHEAD="14"
PICKUP_DEBUG=false

APP_URL="http://localhost:3000"
